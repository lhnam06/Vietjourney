{
  "name": "vietjourney",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm run dev -w @vietjourney/frontend",
    "dev:frontend": "npm run dev -w @vietjourney/frontend",
    "dev:backend": "npm run dev -w @vietjourney/backend",
    "build": "npm run build -w @vietjourney/frontend",
    "build:backend": "npm run build -w @vietjourney/backend",
    "build:all": "npm run build -w @vietjourney/frontend && npm run build -w @vietjourney/backend"
  },
  "engines": {
    "node": ">=20"
  }
}
