## Google Maps (demo)
# Create a key in Google Cloud Console and enable "Maps JavaScript API".
# Optional but recommended: restrict by HTTP referrer and enable billing.
VITE_GOOGLE_MAPS_API_KEY=

## Supabase
# If omitted, the app will fall back to the bundled projectId/publicAnonKey in utils/supabase/info.tsx
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

